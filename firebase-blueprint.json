{
  "entities": {
    "Property": {
      "title": "Property",
      "description": "Real estate property details",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the property" },
        "price": { "type": "string", "description": "Price descriptor" },
        "location": { "type": "string", "description": "Location in Osaka" },
        "type": { "type": "string", "enum": ["OneRoom", "TwoRoom", "Family", "Office", "Investment", "1LDK+S"] },
        "description": { "type": "string", "description": "Detailed description" },
        "images": { "type": "array", "description": "List of image URLs" },
        "features": { "type": "array", "description": "List of feature tags" },
        "construction": { "type": "string" },
        "completionYear": { "type": "string" },
        "nearestStation": { "type": "string" },
        "floorPlan": { "type": "string" },
        "area": { "type": "string" },
        "googleMapUrl": { "type": "string" },
        "youtubeUrl": { "type": "string", "description": "YouTube link for the property tour" },
        "mansionFeatures": { "type": "string", "description": "Specific features of the mansion" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string", "description": "UID of the admin who created it" }
      },
      "required": ["title", "price", "location", "type", "description", "images", "features", "isFeatured", "createdAt", "ownerId"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global configuration for the website",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "consultationBaseCount": { "type": "number" },
        "kakaoId": { "type": "string" },
        "lineId": { "type": "string" },
        "instagramId": { "type": "string" },
        "youtubeUrl": { "type": "string" }
      },
      "required": ["heroTitle", "heroSubtitle"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer feedback",
      "type": "object",
      "properties": {
        "image": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["image", "title", "subtitle", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "User with administrative privileges",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["super", "editor"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "properties/{propertyId}": {
      "schema": "Property",
      "description": "Collection of all real estate listings"
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of customer reviews"
    },
    "admins/{adminId}": {
      "schema": "Admin",
      "description": "Collection of users authorized to manage properties"
    },
    "settings/general": {
      "schema": "SiteSettings",
      "description": "Global singleton for site configuration"
    }
  }
}
