rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'legalj.customer@gmail.com');
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'legalj.customer@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Property Validation ---
    
    function isValidProperty(data) {
      return data.keys().hasAll(['title', 'price', 'location', 'type', 'description', 'images', 'features', 'isFeatured', 'createdAt', 'ownerId']) &&
             data.title is string && data.title.size() <= 300 &&
             data.price is string && data.price.size() <= 200 &&
             data.location is string && data.location.size() <= 300 &&
             data.type in ['OneRoom', 'TwoRoom', 'Family', 'Office', 'Investment', '1LDK+S', 'Studio', '1K', '1LDK', '3LDK', '1LDK+S'] &&
             data.description is string && data.description.size() <= 20000 &&
             data.images is list && data.images.size() <= 30 &&
             data.features is list && data.features.size() <= 50 &&
             data.isFeatured is bool &&
             data.ownerId is string &&
             (!('construction' in data) || data.construction is string) &&
             (!('completionYear' in data) || data.completionYear is string) &&
             (!('nearestStation' in data) || data.nearestStation is string) &&
             (!('floorPlan' in data) || data.floorPlan is string) &&
             (!('area' in data) || data.area is string) &&
             (!('googleMapUrl' in data) || data.googleMapUrl is string) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp || data.updatedAt == null);
    }

    // --- Collections ---

    match /properties/{propertyId} {
      allow read: if true; // Public listings
      
      allow create: if isAdmin() && 
                      isValidId(propertyId) && 
                      isValidProperty(incoming()) &&
                      incoming().ownerId == request.auth.uid &&
                      incoming().createdAt == request.time;
      
      allow update: if isAdmin() && 
                      isValidId(propertyId) && 
                      isValidProperty(incoming()) &&
                      (
                        // Action: General Update
                        (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'price', 'location', 'type', 'description', 'images', 'features', 'isFeatured', 'updatedAt', 'construction', 'completionYear', 'nearestStation', 'floorPlan', 'area', 'googleMapUrl']) &&
                         incoming().updatedAt == request.time &&
                         incoming().createdAt == existing().createdAt &&
                         incoming().ownerId == existing().ownerId)
                      );
                      
      allow delete: if isAdmin() && isValidId(propertyId);
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list: if isAdmin();
      allow create: if isVerified() && request.auth.token.email == 'legalj.customer@gmail.com' && request.auth.uid == adminId;
      allow update, delete: if false;
    }
  }
}
