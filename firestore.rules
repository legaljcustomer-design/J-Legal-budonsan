rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'legalj.customer@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Property Validation ---
    
    function isValidProperty(data) {
      return data.keys().hasAll(['title', 'price', 'location', 'type', 'description', 'images', 'features', 'isFeatured', 'createdAt', 'ownerId']) &&
             data.keys().size() >= 10 &&
             data.title is string && data.title.size() <= 200 &&
             data.price is string && data.price.size() <= 100 &&
             data.location is string && data.location.size() <= 200 &&
             data.type in ['OneRoom', 'TwoRoom', 'Family', 'Office', 'Investment'] &&
             data.description is string && data.description.size() <= 5000 &&
             data.images is list && data.images.size() <= 10 &&
             (data.images.size() == 0 || data.images[0] is string) &&
             data.features is list && data.features.size() <= 20 &&
             (data.features.size() == 0 || data.features[0] is string) &&
             data.isFeatured is bool &&
             data.ownerId == request.auth.uid;
    }

    // --- Collections ---

    match /properties/{propertyId} {
      allow read: if true; // Public listings
      
      allow create: if isAdmin() && 
                      isValidId(propertyId) && 
                      isValidProperty(incoming()) &&
                      incoming().createdAt == request.time;
      
      allow update: if isAdmin() && 
                      isValidId(propertyId) && 
                      isValidProperty(incoming()) &&
                      (
                        // Action: General Update
                        (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'price', 'location', 'type', 'description', 'images', 'features', 'isFeatured', 'updatedAt']) &&
                         incoming().updatedAt == request.time &&
                         incoming().createdAt == existing().createdAt &&
                         incoming().ownerId == existing().ownerId)
                      );
                      
      allow delete: if isAdmin() && isValidId(propertyId);
    }

    match /admins/{adminId} {
      // Allow users to read their own admin doc to check permissions
      allow get: if isSignedIn() && request.auth.uid == adminId;
      // Admins can list other admins
      allow list: if isAdmin();
      // Writing to admins collection is restricted to console/backend for safety
      allow write: if false;
    }
  }
}
